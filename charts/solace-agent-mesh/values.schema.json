{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "imageSpec": {
      "type": "object",
      "description": "Container image configuration with two-tier registry resolution",
      "properties": {
        "registry":   { "type": "string", "description": "Overrides global.imageRegistry for this image only" },
        "repository": { "type": "string", "description": "Image repository name (without registry prefix)" },
        "tag":        { "type": ["string", "number"], "description": "Image tag. Quote in YAML to avoid float parsing (e.g. '18.0')" },
        "digest":     { "type": "string", "description": "Image digest (e.g. sha256:abc...). When set, takes precedence over tag" },
        "pullPolicy": { "type": "string", "enum": ["IfNotPresent", "Always", "Never"] }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "sam": {
      "type": "object",
      "description": "SAM application configuration",
      "properties": {
        "communityMode": {
          "type": "boolean",
          "description": "Internal use only"
        },
        "authorization": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable RBAC authorization. When disabled, all users have unrestricted access."
            }
          },
          "additionalProperties": false
        },
        "dnsName": {
          "type": "string",
          "description": "DNS name for accessing the web UI and API (e.g. sam.example.com). Optional for port-forward and Ingress; required for LoadBalancer/NodePort access."
        },
        "sessionSecretKey": {
          "type": "string",
          "description": "Session encryption secret. Leave empty to auto-generate on first install (stable across upgrades)."
        },
        "oauthProvider": {
          "type": "object",
          "properties": {
            "oidc": {
              "type": "object",
              "properties": {
                "issuer":       { "type": "string", "description": "OIDC issuer URL (e.g. https://accounts.google.com)" },
                "clientId":     { "type": "string", "description": "OIDC client ID" },
                "clientSecret": { "type": "string", "description": "OIDC client secret" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "frontendServerUrl": {
          "type": "string",
          "description": "Override computed frontend URL (e.g. behind a reverse proxy or for local dev)"
        },
        "platformServiceUrl": {
          "type": "string",
          "description": "Override computed platform API URL (e.g. behind a reverse proxy or for local dev)"
        },
        "cors": {
          "type": "object",
          "properties": {
            "allowedOriginRegex": {
              "type": "string",
              "description": "Regex pattern for additional allowed CORS origins"
            }
          },
          "additionalProperties": false
        },
        "taskLogging": {
          "type": "object",
          "description": "Task logging configuration (requires SQL session storage)",
          "properties": {
            "enabled":              { "type": "boolean" },
            "logStatusUpdates":     { "type": "boolean" },
            "logArtifactEvents":    { "type": "boolean" },
            "logFileParts":         { "type": "boolean" },
            "maxFilePartSizeBytes": { "type": "integer" },
            "hybridBuffer": {
              "type": "object",
              "properties": {
                "enabled":        { "type": "boolean" },
                "flushThreshold": { "type": "integer" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "authenticationRbac": {
          "type": "object",
          "description": "RBAC configuration. Choose ONE method: static users OR idpClaims (dynamic from IDP).",
          "properties": {
            "customRoles": {
              "type": "object",
              "description": "Custom role definitions",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "scopes":      { "type": "array", "items": { "type": "string" } }
                },
                "additionalProperties": false
              }
            },
            "users": {
              "type": "array",
              "description": "Static user-to-role assignments",
              "items": {
                "type": "object",
                "properties": {
                  "identity":    { "type": "string", "description": "User identifier (email, username, etc.)" },
                  "roles":       { "type": "array", "items": { "type": "string" } },
                  "description": { "type": "string" }
                },
                "required": ["identity", "roles"],
                "additionalProperties": false
              }
            },
            "idpClaims": {
              "type": "object",
              "description": "Dynamic role assignment from IDP claims (alternative to static users)",
              "properties": {
                "enabled":      { "type": "boolean" },
                "oidcProvider": { "type": "string", "description": "OIDC provider name" },
                "claimKey":     { "type": "string", "description": "OIDC claim key to extract roles from." },
                "mappings": {
                  "type": "object",
                  "description": "Map IDP claim values to SAM roles",
                  "additionalProperties": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "additionalProperties": false
            },
            "defaultRoles": {
              "type": "array",
              "description": "Default roles assigned to users not matching any explicit assignment or IDP mapping",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "featureEnablement": {
          "type": "object",
          "description": "Legacy feature flags.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "broker": {
      "type": "object",
      "description": "Solace event broker connection configuration. Only used when global.broker.embedded is false.",
      "properties": {
        "url":            { "type": "string", "description": "Solace event broker connection URL" },
        "clientUsername": { "type": "string", "description": "Client username for authenticating with the Solace event broker" },
        "password":       { "type": "string", "description": "Client password for authenticating with the Solace event broker" },
        "vpn":            { "type": "string", "description": "Solace broker Message VPN name" }
      },
      "additionalProperties": false
    },
    "llmService": {
      "type": "object",
      "description": "LLM service configuration for AI model access",
      "properties": {
        "planningModel":      { "type": "string", "description": "Model name for planning tasks (e.g. gpt-4o)" },
        "generalModel":       { "type": "string", "description": "Model name for general tasks" },
        "reportModel":        { "type": "string", "description": "Model name for report generation" },
        "imageModel":         { "type": "string", "description": "Model name for image generation (e.g. dall-e-3)" },
        "transcriptionModel": { "type": "string", "description": "Model name for audio transcription (e.g. whisper-1)" },
        "llmServiceEndpoint": { "type": "string", "description": "LLM service API endpoint URL" },
        "llmServiceApiKey":   { "type": "string", "description": "LLM service API key" }
      },
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "description": "Kubernetes Service configuration.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "description": "Service type: One of ClusterIP, NodePort, or LoadBalancer"
        },
        "annotations": {
          "type": "object",
          "description": "Service annotations (e.g. cloud-provider LoadBalancer hints)"
        },
        "nodePorts": {
          "type": "object",
          "description": "NodePort assignments (30000-32767). Only used when type=NodePort; leave empty for auto-assignment.",
          "properties": {
            "http":          { "type": ["string", "integer"], "description": "WebUI HTTP NodePort" },
            "https":         { "type": ["string", "integer"], "description": "WebUI HTTPS NodePort" },
            "auth":          { "type": ["string", "integer"], "description": "Auth Service NodePort" },
            "platformHttp":  { "type": ["string", "integer"], "description": "Platform API HTTP NodePort" },
            "platformHttps": { "type": ["string", "integer"], "description": "Platform API HTTPS NodePort" }
          },
          "additionalProperties": false
        },
        "tls": {
          "type": "object",
          "description": "TLS/SSL configuration for pod-level TLS termination",
          "properties": {
            "enabled":        { "type": "boolean", "description": "Enable TLS on the service. Controls health check ports, URL scheme, and TLS secret creation." },
            "existingSecret": { "type": "string", "description": "Name of an existing kubernetes.io/tls Secret (alternative to inline cert/key)" },
            "cert":           { "type": "string", "description": "TLS certificate content (PEM-encoded)" },
            "key":            { "type": "string", "description": "TLS private key content (PEM-encoded)" },
            "passphrase":     { "type": "string", "description": "TLS private key passphrase (passed to TLS server library)" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "description": "Kubernetes Ingress configuration. App-level fields are typed; K8s fields (annotations, hosts, tls) are allowed but not restricted.",
      "properties": {
        "enabled":            { "type": "boolean", "description": "Enable Ingress resource creation. Affects OAuth redirect URL computation." },
        "className":          { "type": "string", "description": "Ingress class name (e.g. nginx, traefik, alb)" },
        "autoConfigurePaths": { "type": "boolean", "description": "Auto-generate all required ingress paths (recommended). Set to false for custom routing." },
        "host":               { "type": "string", "description": "Hostname for auto-configured ingress paths. Leave empty for ALB controllers." },
        "annotations":        { "type": "object", "description": "Ingress annotations (controller-specific, e.g. nginx.ingress.kubernetes.io/*, alb.ingress.kubernetes.io/*)" },
        "hosts":              { "type": "array",  "description": "Manual hosts/paths configuration. Only used when autoConfigurePaths is false." },
        "tls":                { "type": "array",  "description": "TLS configuration (secretName + hosts). Presence triggers HTTPS URL generation." }
      },
      "additionalProperties": false
    },
    "environmentVariables": {
      "description": "Custom environment variables injected into the SAM core deployment. Can be a map of key-value pairs or a multiline KEY=VALUE string.",
      "oneOf": [
        { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
        { "type": "string" }
      ]
    },
    "global": {
      "type": "object",
      "description": "Global configuration shared across chart and subcharts",
      "required": ["persistence"],
      "properties": {
        "imageRegistry": { "type": "string", "description": "Default container image registry for all images (e.g. gcr.io/gcp-maas-prod). Per-image override via image.registry." },
        "imagePullSecrets": {
          "type": "array",
          "description": "Image pull secrets applied to ALL pods (core, agent-deployer, postgresql, seaweedfs)",
          "items": { "type": "string" }
        },
        "imagePullKey": {
          "type": "string",
          "description": "Pull-credentials JSON for private registries. Expects the K8s Secret data shape `{ \".dockerconfigjson\": \"<base64>\" }`. Use --set-file global.imagePullKey=path/to/creds.json."
        },
        "broker": {
          "type": "object",
          "description": "Embedded Solace broker configuration",
          "properties": {
            "embedded": {
              "type": "boolean",
              "description": "Deploy an embedded Solace broker (dev/quickstart only). When false, provide connection details for an external broker in the top-level 'broker' section."
            }
          },
          "additionalProperties": false
        },
        "persistence": {
          "type": "object",
          "required": ["namespaceId"],
          "properties": {
            "namespaceId": {
              "type": "string",
              "minLength": 1,
              "description": "Unique identifier for this SAM installation. Used for database names, S3 bucket scoping, and topic namespacing."
            },
            "enabled": {
              "type": "boolean",
              "description": "Enable bundled PostgreSQL + SeaweedFS (dev/POC only). Set to false for production with external datastores."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "samDeployment": {
      "type": "object",
      "description": "SAM deployment configuration.",
      "properties": {
        "serviceAccount": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name":        { "type": "string", "description": "Service account name. Must also match persistence-layer.postgresql/seaweedfs.serviceAccountName when using bundled persistence." },
            "annotations": { "type": "object", "description": "ServiceAccount annotations (e.g. for workload identity)" }
          },
          "additionalProperties": false
        },
        "imagePullSecret": {
          "type": "string",
          "description": "Image pull secret name attached to the service account for private registries"
        },
        "image": { "$ref": "#/definitions/imageSpec" },
        "agentDeployer": {
          "type": "object",
          "description": "Deployer configuration",
          "properties": {
            "image": { "$ref": "#/definitions/imageSpec" },
            "version":      { "type": "string", "description": "Deployer version identifier" },
            "chartVersion": { "type": "string", "description": "Chart version for the solace-agent-mesh-agent chart" },
            "kubeApiHost":  { "type": "string", "description": "Kubernetes API host the deployer's helm client dials. Override applied only when HTTP_PROXY/HTTPS_PROXY is set; allows the .svc NO_PROXY rule to bypass the proxy. Empty string disables the override." }
          },
          "additionalProperties": false
        },
        "dbInit": {
          "type": "object",
          "properties": {
            "image": { "$ref": "#/definitions/imageSpec" }
          },
          "additionalProperties": false
        },
        "s3Init": {
          "type": "object",
          "properties": {
            "image": { "$ref": "#/definitions/imageSpec" }
          },
          "additionalProperties": false
        },
        "customCA": {
          "type": "object",
          "description": "Custom CA certificate injection. Enables a ca-merge init container that appends *.crt files from a ConfigMap onto the system CA bundle.",
          "properties": {
            "enabled":       { "type": "boolean", "description": "Enable custom CA bundle injection via ca-merge init container" },
            "configMapName": { "type": "string", "description": "Name of the ConfigMap in the release namespace containing *.crt files" }
          },
          "additionalProperties": false
        },
        "caInitImage": {
          "allOf": [{ "$ref": "#/definitions/imageSpec" }],
          "description": "Optional image override for the ca-merge init container. Defaults to samDeployment.image when empty. Must be a Debian-based image (needs /etc/ssl/certs/ca-certificates.crt). Only used when samDeployment.customCA.enabled is true."
        },
        "rollout": {
          "type": "object",
          "description": "Deployment rollout strategy configuration",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["RollingUpdate", "Recreate"],
              "description": "Deployment update strategy"
            },
            "rollingUpdate": { "type": "object" }
          },
          "additionalProperties": false
        },
        "podSecurityContext": { "description": "Pod-level security context (K8s passthrough)" },
        "securityContext":    { "description": "Container-level security context (K8s passthrough)" },
        "nodeSelector":       { "type": "object", "description": "Node selector constraints (K8s passthrough)" },
        "tolerations":        { "type": "array",  "description": "Pod tolerations (K8s passthrough)" },
        "annotations":        { "type": "object", "description": "Deployment annotations (K8s passthrough)" },
        "podAnnotations":     { "type": "object", "description": "Pod annotations (K8s passthrough)" },
        "podLabels":          { "type": "object", "description": "Pod labels (K8s passthrough)" },
        "resources":          { "type": "object", "description": "Resource requests and limits for sam and agentDeployer containers" }
      },
      "additionalProperties": false
    },
    "extraSecretEnvironmentVars": {
      "type": "array",
      "description": "Reference values from existing Kubernetes Secrets as environment variables",
      "items": {
        "type": "object",
        "required": ["envName", "secretName", "secretKey"],
        "properties": {
          "envName":    { "type": "string", "description": "Environment variable name to set" },
          "secretName": { "type": "string", "description": "Name of the existing Kubernetes Secret" },
          "secretKey":  { "type": "string", "description": "Key within the Secret to read the value from" }
        },
        "additionalProperties": false
      }
    },
    "dataStores": {
      "type": "object",
      "description": "External datastore configuration (database and object storage)",
      "properties": {
        "database": {
          "type": "object",
          "properties": {
            "protocol":            { "type": "string", "description": "Database connection protocol (e.g. postgresql+psycopg2)" },
            "host":                { "type": "string", "description": "Database hostname" },
            "port":                { "type": ["string", "integer"], "description": "Database port" },
            "adminUsername":       { "type": "string", "description": "Database admin username" },
            "adminPassword":       { "type": "string", "description": "Database admin password" },
            "applicationPassword": { "type": "string", "description": "Application database user password. Required when global.persistence.enabled=false." },
            "supabaseTenantId":    { "type": "string", "description": "Supabase project ID for connection pooler username qualification" }
          },
          "additionalProperties": false
        },
        "objectStorage": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["s3", "azure", "gcs"],
              "description": "Object storage backend type"
            },
            "workloadIdentity": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "description": "Use workload identity for object storage authentication (no access keys)" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "s3": {
          "type": "object",
          "properties": {
            "endpointUrl":            { "type": "string", "description": "S3-compatible endpoint URL" },
            "bucketName":             { "type": "string", "description": "S3 bucket for data storage" },
            "connectorSpecBucketName": { "type": "string", "description": "S3 bucket for connector specs" },
            "evalDataBucketName":     { "type": "string", "description": "Optional S3 bucket for eval execution data; defaults to bucketName when empty" },
            "accessKey":              { "type": "string", "description": "S3 access key" },
            "secretKey":              { "type": "string", "description": "S3 secret key" },
            "region":                 { "type": "string", "description": "S3 region (e.g. us-east-1)" }
          },
          "additionalProperties": false
        },
        "azure": {
          "type": "object",
          "properties": {
            "accountName":                { "type": "string", "description": "Azure storage account name" },
            "accountKey":                 { "type": "string", "description": "Azure storage account key" },
            "connectionString":           { "type": "string", "description": "Azure storage connection string" },
            "containerName":              { "type": "string", "description": "Azure blob container for data storage" },
            "connectorSpecContainerName": { "type": "string", "description": "Azure blob container for connector specs" },
            "evalDataContainerName":      { "type": "string", "description": "Optional Azure blob container for eval execution data; defaults to containerName when empty" }
          },
          "additionalProperties": false
        },
        "gcs": {
          "type": "object",
          "properties": {
            "project":                 { "type": "string", "description": "GCP project ID" },
            "credentialsJson":         { "type": "string", "description": "GCP service account credentials JSON" },
            "bucketName":              { "type": "string", "description": "GCS bucket for data storage" },
            "connectorSpecBucketName": { "type": "string", "description": "GCS bucket for connector specs" },
            "evalDataBucketName":      { "type": "string", "description": "Optional GCS bucket for eval execution data; defaults to bucketName when empty" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "embeddedBroker": {
      "type": "object",
      "description": "Embedded Solace broker configuration. Only deployed when global.broker.embedded is true.",
      "properties": {
        "image": { "$ref": "#/definitions/imageSpec" },
        "imagePullSecrets": {
          "type": "array",
          "description": "Component-level image pull secrets (merged with global.imagePullSecrets)",
          "items": { "type": "string" }
        },
        "resources":        { "type": "object", "description": "Kubernetes resource requests and limits. Minimum memory: 2480Mi." },
        "storageClassName": { "type": "string", "description": "Storage class name for broker PVC. Uses cluster default if not specified." },
        "shmSize":          { "type": "string", "description": "Shared memory size limit for /dev/shm (minimum: 1Gi)" }
      },
      "additionalProperties": false
    },
    "samDoctor": {
      "type": "object",
      "description": "Pre-install/upgrade validation hook (sam-doctor). Runs as a Helm pre-install/pre-upgrade job to validate configuration before deploying SAM.",
      "properties": {
        "enabled":        { "type": "boolean", "description": "Enable the sam-doctor pre-install/upgrade hook" },
        "failOnError":    { "type": "boolean", "description": "When false, the hook always exits 0 even when checks fail" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "description": "activeDeadlineSeconds for the hook job" },
        "tlsDnsName":     { "type": "string", "description": "DNS name used to validate the TLS certificate. Defaults to sam.dnsName if unset." }
      },
      "additionalProperties": false
    },
    "validations": {
      "type": "object",
      "description": "Template-time cluster resource existence checks. Looks up referenced Secrets, ConfigMaps, StorageClasses, and IngressClasses before install to surface missing resources early. Requires 'get' RBAC on each referenced resource.",
      "properties": {
        "clusterResourceChecks": {
          "type": "boolean",
          "description": "Enable template-time existence checks for referenced cluster resources. Set to false if the service account lacks 'get' permission."
        }
      },
      "additionalProperties": false
    },
    "sam-common":                 { "type": "object", "additionalProperties": true, "description": "sam-common library subchart values (no-op at render time; library chart)" },
    "persistence-layer":          { "type": "object", "additionalProperties": true },
    "deploymentId":               { "type": "string", "description": "Optional deployment identifier label on the Service resource" },
    "datadog":                    { "type": "object", "additionalProperties": true, "description": "Datadog tags configuration (internal)" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "global": {
            "properties": {
              "persistence": {
                "properties": { "enabled": { "const": true } }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "dataStores": {
            "description": "Cannot provide external datastore configuration when global.persistence.enabled is true. Either set global.persistence.enabled to false and provide datastore credentials, or remove the datastore configuration to use bundled persistence.",
            "properties": {
              "database": {
                "properties": {
                  "host":                { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "adminUsername":       { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "adminPassword":       { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "applicationPassword": { "maxLength": 0, "description": "Must be empty when using bundled persistence" }
                }
              },
              "s3": {
                "properties": {
                  "endpointUrl": { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "accessKey":   { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "secretKey":   { "maxLength": 0, "description": "Must be empty when using bundled persistence" }
                }
              },
              "azure": {
                "properties": {
                  "accountName":       { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "accountKey":        { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "connectionString":  { "maxLength": 0, "description": "Must be empty when using bundled persistence" }
                }
              },
              "gcs": {
                "properties": {
                  "project":         { "maxLength": 0, "description": "Must be empty when using bundled persistence" },
                  "credentialsJson": { "maxLength": 0, "description": "Must be empty when using bundled persistence" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "global": {
            "properties": {
              "persistence": {
                "properties": { "enabled": { "const": false } }
              }
            }
          },
          "dataStores": {
            "properties": {
              "objectStorage": {
                "properties": { "type": { "const": "s3" } }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "dataStores": {
            "properties": {
              "s3": {
                "required": ["endpointUrl", "bucketName"],
                "properties": {
                  "endpointUrl": { "type": "string", "minLength": 1 },
                  "bucketName":  { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "global": {
            "properties": {
              "persistence": {
                "properties": { "enabled": { "const": false } }
              }
            }
          },
          "dataStores": {
            "properties": {
              "objectStorage": {
                "properties": {
                  "type": { "const": "s3" },
                  "workloadIdentity": {
                    "properties": { "enabled": { "const": false } }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "dataStores": {
            "properties": {
              "s3": {
                "required": ["accessKey", "secretKey"],
                "properties": {
                  "accessKey": { "type": "string", "minLength": 1 },
                  "secretKey": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
